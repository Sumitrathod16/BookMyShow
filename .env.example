# Email Configuration Example
# Copy this to .env and fill in actual values

# SMTP Email Server Configuration
# Set to 'True' to use SMTP, 'False' to use console backend (development)
USE_SMTP_EMAIL=False

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-character-app-password

# OR SendGrid Configuration Example
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=SG.your-sendgrid-api-key

# OR AWS SES Configuration Example
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-ses-smtp-username
# EMAIL_HOST_PASSWORD=your-ses-smtp-password

# Email Addresses
DEFAULT_FROM_EMAIL=noreply@bookmyseat.com
SUPPORT_EMAIL=support@bookmyseat.com

# Email Delivery Configuration
EMAIL_TIMEOUT=10
EMAIL_MAX_ATTEMPTS=5
EMAIL_RETRY_DELAY_MINUTES=1

# Database Configuration
# For development: leave empty (uses SQLite)
# For production: use PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/bookmyseat
